@inject NavigationManager Nav

<div class="group-card card @GetBorderClass()">
	<div class="card-header d-flex justify-content-between align-items-center" role="button" @onclick="ToggleExpand">
		<div>
			<strong>Group @Group.GroupNumber</strong>
			<ConfidenceBadge Confidence="@Group.Confidence" />
			<span class="text-muted ms-2 small">@Group.DocumentCount doc(s)</span>
		</div>
		<div class="d-flex align-items-center gap-2">
			@if (Group.DocumentCount > 1)
			{
				<button class="btn btn-sm btn-outline-primary" @onclick="NavigateToCompare" @onclick:stopPropagation="true">
					<i class="bi bi-arrows-angle-expand"></i> Compare
				</button>
			}
			<i class="bi @(IsExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
		</div>
	</div>

	@if (IsExpanded)
	{
		<div class="card-body">
			@if (!string.IsNullOrWhiteSpace(Group.MatchReason))
			{
				<p class="small text-muted mb-2"><strong>Match reason:</strong> @Group.MatchReason</p>
			}

			<table class="table table-sm table-hover mb-0">
				<thead>
					<tr>
						<th>File</th>
						<th>Words</th>
						<th>Role</th>
						<th>Expected</th>
						<th>Preview</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var doc in Group.Documents)
					{
						<tr>
							<td class="text-nowrap">@doc.FileName</td>
							<td>@doc.WordCount</td>
							<td>
								@if (doc.IsCanonical)
								{
									<span class="badge bg-success">Canonical</span>
								}
							</td>
							<td>
								@{ var expected = GetExpectedSimilarity(doc); }
								@if (expected is not null)
								{
									<span class="badge @GetExpectedBadgeClass(expected)">@FormatSimilarity(expected)</span>
								}
							</td>
							<td class="small text-muted text-truncate" style="max-width: 300px;">
								@(doc.PreviewText.Length > 200 ? doc.PreviewText[..200] + "..." : doc.PreviewText)
							</td>
							<td>
								@if (doc.HasPdf)
								{
									<button class="btn btn-sm btn-outline-secondary" @onclick="() => TogglePdfViewer(doc.Id)" @onclick:stopPropagation="true">
										<i class="bi bi-file-earmark-pdf"></i> @(_viewingPdfId == doc.Id ? "Hide PDF" : "View PDF")
									</button>
								}
							</td>
						</tr>
						@if (_viewingPdfId == doc.Id)
						{
							<tr>
								<td colspan="6" class="p-0">
									<iframe src="/api/documents/@doc.Id/pdf?db=@DatabaseName"
											style="width:100%; height:600px; border:none;"></iframe>
								</td>
							</tr>
						}
					}
				</tbody>
			</table>

			@if (Group.MatchExplanation is not null)
			{
				<MatchExplanation Explanation="@Group.MatchExplanation" />
			}
		</div>
	}
</div>

@code {
	[Parameter] public GroupDto Group { get; set; } = null!;
	[Parameter] public string DatabaseName { get; set; } = "";

	private bool IsExpanded { get; set; }
	private Guid? _viewingPdfId;

	private void ToggleExpand() => IsExpanded = !IsExpanded;

	private void TogglePdfViewer(Guid docId)
	{
		_viewingPdfId = _viewingPdfId == docId ? null : docId;
	}

	private void NavigateToCompare() => Nav.NavigateTo($"/comparison/{Group.GroupNumber}");

	private string GetBorderClass() => Group.Confidence?.ToLowerInvariant() switch
	{
		"veryhigh" or "exact" => "border-confidence-veryhigh",
		"high" => "border-confidence-high",
		"medium" => "border-confidence-medium",
		_ => "border-confidence-none"
	};

	private static string? GetExpectedSimilarity(DocumentDto doc)
	{
		if (doc.Metadata.TryGetValue("expected_similarity", out var val) && val is string s)
			return s;
		return null;
	}

	private static string GetExpectedBadgeClass(string similarity) => similarity switch
	{
		"very_high" => "bg-danger",
		"high" => "bg-warning text-dark",
		"medium" => "bg-primary",
		"unique" => "bg-secondary",
		_ => "bg-light text-dark"
	};

	private static string FormatSimilarity(string similarity) => similarity switch
	{
		"very_high" => "VeryHigh",
		"high" => "High",
		"medium" => "Medium",
		"unique" => "Unique",
		_ => similarity
	};
}
