@{
	var segAdded = DiffLines.Count(l => l.Type == DiffType.Added);
	var segRemoved = DiffLines.Count(l => l.Type == DiffType.Removed);
	var segSame = DiffLines.Count(l => l.Type == DiffType.Same);
}

<div class="card">
	<div class="card-body">
		<h6>Word-Level Summary</h6>
		@if (WordStats is not null)
		{
			<ul class="list-unstyled mb-3">
				<li><i class="bi bi-file-text me-2"></i> <strong>Doc 1 words:</strong> @WordStats.TotalWords1</li>
				<li><i class="bi bi-file-text me-2"></i> <strong>Doc 2 words:</strong> @WordStats.TotalWords2</li>
				<li><i class="bi bi-check-circle me-2"></i> <strong>Common words:</strong> @WordStats.CommonWords</li>
				<li class="text-success"><i class="bi bi-plus-circle me-2"></i> <strong>Added:</strong> @WordStats.AddedWords words</li>
				<li class="text-danger"><i class="bi bi-dash-circle me-2"></i> <strong>Removed:</strong> @WordStats.RemovedWords words</li>
				<li><i class="bi bi-percent me-2"></i> <strong>Word match:</strong> @WordStats.SimilarityPct.ToString("F1")%</li>
			</ul>
		}

		<h6 class="mt-3">Segment Diff</h6>
		<ul class="list-unstyled mb-3">
			<li class="text-success"><i class="bi bi-plus-circle me-2"></i> <strong>Added:</strong> @segAdded segments</li>
			<li class="text-danger"><i class="bi bi-dash-circle me-2"></i> <strong>Removed:</strong> @segRemoved segments</li>
			<li><i class="bi bi-check-circle me-2"></i> <strong>Unchanged:</strong> @segSame segments</li>
		</ul>

		@if (segAdded > 0 || segRemoved > 0)
		{
			<h6 class="mt-3">Key Differences</h6>
			<div class="small" style="max-height: 300px; overflow-y: auto;">
				@{
					var hunks = GetHunks();
				}
				@foreach (var hunk in hunks.Take(10))
				{
					<div class="mb-2 border-start border-3 ps-2 @(hunk.Type == DiffType.Added ? "border-success" : "border-danger")">
						<span class="badge @(hunk.Type == DiffType.Added ? "bg-success" : "bg-danger") me-1">
							@(hunk.Type == DiffType.Added ? "+" : "-")
						</span>
						<span class="text-muted">Segment @hunk.LineNumber:</span>
						<span>@Truncate(hunk.Content, 120)</span>
					</div>
				}
				@if (hunks.Count > 10)
				{
					<p class="text-muted">...and @(hunks.Count - 10) more differences</p>
				}
			</div>
		}
		else
		{
			<div class="alert alert-success mb-0">
				<i class="bi bi-check2-all"></i> Documents are identical.
			</div>
		}
	</div>
</div>

@code {
	[Parameter] public List<DiffLine> DiffLines { get; set; } = [];
	[Parameter] public WordDiffStats? WordStats { get; set; }

	private record HunkInfo(DiffType Type, int LineNumber, string Content);

	private List<HunkInfo> GetHunks()
	{
		return DiffLines
			.Where(l => l.Type != DiffType.Same)
			.Select(l => new HunkInfo(l.Type, l.Line1 ?? l.Line2 ?? 0, l.Content))
			.ToList();
	}

	private static string Truncate(string text, int max)
		=> text.Length > max ? text[..max] + "..." : text;
}
