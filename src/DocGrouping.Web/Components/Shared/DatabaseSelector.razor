@rendermode InteractiveServer
@using DocGrouping.Web.Services
@inject DatabaseSelectorState DbState
@inject DatabaseInitializer DbInit
@inject NavigationManager Nav

<div class="d-flex align-items-center gap-2">
    <label class="text-muted small mb-0" for="db-selector">Database:</label>
    <select id="db-selector" class="form-select form-select-sm" style="width: auto;"
            @bind="selectedDb" @bind:after="OnDatabaseChanged">
        @foreach (var db in DbState.AvailableDatabases)
        {
            <option value="@db">@db</option>
        }
    </select>
</div>

@code {
    private string selectedDb = "";

    protected override void OnInitialized()
    {
        selectedDb = DbState.ActiveDatabaseName;
    }

    private async Task OnDatabaseChanged()
    {
        if (string.IsNullOrEmpty(selectedDb) || selectedDb == DbState.ActiveDatabaseName)
            return;

        await DbInit.EnsureCreatedAsync(selectedDb);
        DbState.ActiveDatabaseName = selectedDb;
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }
}
